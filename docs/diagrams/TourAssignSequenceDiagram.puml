@startuml
actor User
participant "LogicManager" as Logic
participant "TourAssignCommandParser" as Parser
participant "TourAssignCommand" as Command
participant "Model" as Model
participant "Contact" as Contact

User -> Logic : execute("tour-assign 1 tour/2")
Logic -> Parser : parse("1 tour/2")
Parser --> Logic : TourAssignCommand

Logic -> Command : execute(model)
Command -> Model : getFilteredContactList()
Model --> Command : currently displayed contact list
Command -> Command : getContact(contactList, contactIndex)
Command -> Model : getFilteredTourList()
Model --> Command : currently displayed tour list
Command -> Command : getTour(tourList, tourIndex)
Command -> Command : validateNotAssigned(contact, tour)
Command -> Contact : buildContactWithTourAdded(contact, tour)
Contact --> Command : updatedContact
Command -> Model : setContact(contact, updatedContact)
Command -> Model : commitAddressBook()
Command --> Logic : CommandResult
Logic --> User : "Assigned tour to contact: ..."
@enduml
